{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model-proxy/contracts/api/admin/monitoring/openai-chatgpt-accounts-page.schema.json",
  "title": "OpenAI ChatGPT admin monitoring accounts page v1",
  "description": "Provider-specific admin read-model for the openai-chatgpt monitoring page.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_id",
    "display_name",
    "capabilities",
    "security_boundary",
    "groups"
  ],
  "$defs": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "used_percent",
        "window_minutes"
      ],
      "properties": {
        "used_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "window_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "reset_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "refresh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_refreshed_at",
        "refresh_interval_seconds",
        "status"
      ],
      "properties": {
        "last_refreshed_at": {
          "type": "string",
          "format": "date-time"
        },
        "next_refresh_at": {
          "type": "string",
          "format": "date-time"
        },
        "refresh_interval_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "refreshing",
            "error"
          ]
        },
        "last_error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "quota_blocked_until": {
          "type": "string",
          "format": "date-time"
        },
        "block_reason": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": true
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_activate",
        "activate_semantics"
      ],
      "properties": {
        "can_activate": {
          "type": "boolean"
        },
        "activate_endpoint": {
          "type": "string",
          "minLength": 1
        },
        "activate_semantics": {
          "type": "string",
          "const": "session_scoped_in_memory_preferred_account_override"
        }
      }
    },
    "drawer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_monitoring_payload": {
          "type": "object",
          "additionalProperties": true
        },
        "raw_request_usage_payload": {
          "type": "object",
          "additionalProperties": true
        },
        "raw_account_state_payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_name",
        "status",
        "short_window",
        "long_window",
        "refresh",
        "routing",
        "actions"
      ],
      "properties": {
        "account_name": {
          "type": "string",
          "minLength": 1
        },
        "is_preferred_for_session": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "ready",
            "cooldown",
            "quota_blocked",
            "blocked"
          ]
        },
        "short_window": {
          "$ref": "#/$defs/window"
        },
        "long_window": {
          "$ref": "#/$defs/window"
        },
        "refresh": {
          "$ref": "#/$defs/refresh"
        },
        "routing": {
          "$ref": "#/$defs/routing"
        },
        "actions": {
          "$ref": "#/$defs/actions"
        },
        "drawer": {
          "$ref": "#/$defs/drawer"
        }
      }
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "display_name",
        "accounts"
      ],
      "properties": {
        "group_id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "runtime_group_key": {
          "type": "string",
          "minLength": 1
        },
        "refresh": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "processed_accounts",
            "total_accounts",
            "successful_accounts",
            "failed_accounts"
          ],
          "properties": {
            "refresh_id": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": [
                "idle",
                "queued",
                "running",
                "completed",
                "completed_with_errors",
                "error"
              ]
            },
            "processed_accounts": {
              "type": "integer",
              "minimum": 0
            },
            "total_accounts": {
              "type": "integer",
              "minimum": 0
            },
            "successful_accounts": {
              "type": "integer",
              "minimum": 0
            },
            "failed_accounts": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "accounts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/account"
          }
        }
      }
    }
  },
  "properties": {
    "provider_id": {
      "type": "string",
      "const": "openai-chatgpt"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supports_activate",
        "supports_drawer",
        "supports_usage_windows",
        "supports_manual_refresh"
      ],
      "properties": {
        "supports_activate": {
          "type": "boolean"
        },
        "supports_drawer": {
          "type": "boolean"
        },
        "supports_usage_windows": {
          "type": "boolean"
        },
        "supports_manual_refresh": {
          "type": "boolean"
        }
      }
    },
    "security_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auth_mode",
        "scope",
        "shared_deployment_allowed"
      ],
      "properties": {
        "auth_mode": {
          "type": "string",
          "const": "none"
        },
        "scope": {
          "type": "string",
          "const": "local_single_user_poc"
        },
        "shared_deployment_allowed": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "refresh_interval_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    }
  }
}
