# === Google Cloud Configuration ===

# --- Vertex AI Mode (Credits) ---
# ID проекта, где включен Vertex AI API и привязан биллинг ($10 credits)
# Внимание: Это ID (my-project-123), а не Name (My Project)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# --- Quota Mode (OAuth / Gemini CLI Emulation) ---
# Опционально: Принудительно задать ID проекта для квот.
# Если не задано, прокси попытается обнаружить его автоматически.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Quota parity controls ---
# Делает outbound quota transport максимально близким к gemini-cli (рекомендуется true)
STRICT_CLI_PARITY=true
# Дефолтная модель для OpenAI-compatible запросов без поля model
DEFAULT_QUOTA_MODEL=gemini-3-flash-preview-quota
# Переопределение Cloud Code endpoint (можно указывать capture-relay)
CLOUD_CODE_ENDPOINT=https://cloudcode-pa.googleapis.com/v1internal
# OAuth client для режима эмуляции gemini-cli.
# Обязателен для refresh Gemini quota токенов и запуска `scripts/get_gemini-cli_credentials.py`.
GEMINI_CLI_CLIENT_ID=your-gemini-cli-client-id
GEMINI_CLI_CLIENT_SECRET=your-gemini-cli-client-secret

# --- Provider-specific OAuth credentials paths ---
USER_GEMINI_CREDS_PATH=secrets/user_gemini_credentials.json
USER_QWEN_CREDS_PATH=secrets/user_qwen_credentials.json
USER_OPENAI_CHATGPT_CREDS_PATH=/app/state/openai-chatgpt/auth/oauth-account.json

# --- Provider-specific accounts rotation configs ---
GEMINI_ACCOUNTS_CONFIG_PATH=secrets/gemini-cli/accounts_config.json
QWEN_ACCOUNTS_CONFIG_PATH=secrets/qwen_code/accounts_config.json
OPENAI_CHATGPT_ACCOUNTS_CONFIG_PATH=secrets/openai-chatgpt/accounts_config.json

# --- Runtime state persistence ---
# Отдельная директория для runtime state (`account_state.json`, `quota_state.json`).
# В контейнере обычно монтируется на HDD.
STATE_DIR=/app/state
# Интервал flush async writer в секундах.
STATE_FLUSH_INTERVAL_SECONDS=3
# Максимум уникальных файлов в pending coalesce map.
STATE_WRITER_MAX_PENDING_FILES=1024

# --- Qwen OAuth bootstrap (только для `scripts/get_qwen-code_credentials.py`) ---
# Runtime прокси берёт client_id из credentials-файла аккаунта, а не из env.
# Эти параметры нужны только для первичного device-flow получения credentials.
# Значение совпадает с qwen-code upstream.
QWEN_OAUTH_CLIENT_ID=f0304373b74a44d2b584a3fb70ca9e56
# Рекомендуемое значение scope для qwen OAuth device-flow.
QWEN_OAUTH_SCOPE=openid profile email model.completion
QWEN_OAUTH_DEVICE_CODE_ENDPOINT=https://chat.qwen.ai/api/v1/oauth2/device/code
QWEN_OAUTH_TOKEN_ENDPOINT=https://chat.qwen.ai/api/v1/oauth2/token
QWEN_DEFAULT_RESOURCE_URL=https://dashscope.aliyuncs.com/compatible-mode
QWEN_REFRESH_IDLE_THRESHOLD_SECONDS=180

# --- OpenAI ChatGPT OAuth bootstrap/runtime ---
# Bootstrap Authorization Code + PKCE script reads these values locally.
# Reference KiloCode client_id from [`externel_projects/kilocode/src/integrations/openai-codex/oauth.ts`](externel_projects/kilocode/src/integrations/openai-codex/oauth.ts:17)
OPENAI_CHATGPT_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_CHATGPT_OAUTH_SCOPE=openid profile email offline_access
OPENAI_CHATGPT_OAUTH_AUTHORIZE_ENDPOINT=https://auth.openai.com/oauth/authorize
OPENAI_CHATGPT_OAUTH_TOKEN_ENDPOINT=https://auth.openai.com/oauth/token
OPENAI_CHATGPT_OAUTH_CALLBACK_HOST=localhost
OPENAI_CHATGPT_OAUTH_CALLBACK_PORT=1455
OPENAI_CHATGPT_OAUTH_CALLBACK_PATH=/auth/callback

# Runtime adapter for private backend surface.
OPENAI_CHATGPT_USER_AGENT=kilo-code
# Reference KiloCode originator from [`externel_projects/kilocode/src/integrations/openai-codex/oauth.ts`](externel_projects/kilocode/src/integrations/openai-codex/oauth.ts:203)
OPENAI_CHATGPT_ORIGINATOR=kilo-code
OPENAI_CHATGPT_BACKEND_BASE_URL=https://chatgpt.com/backend-api/codex
OPENAI_CHATGPT_RESPONSES_PATH=/responses
OPENAI_CHATGPT_USAGE_URL=https://chatgpt.com/backend-api/wham/usage
OPENAI_CHATGPT_REFRESH_BUFFER_SECONDS=300

# --- HTTP pool tuning ---
HTTP_TIMEOUT_SECONDS=60
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
