{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://model-proxy.local/contracts/api/admin/api-keys/openai-chatgpt-api-key-revoke-response.schema.json",
  "title": "OpenAIChatGPTAdminApiKeyRevokeResponse",
  "description": "Admin API response returned after revoking a platform API key.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "key_id",
    "status"
  ],
  "properties": {
    "ok": {
      "type": "boolean",
      "const": true
    },
    "key_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "revoked"
    }
  }
}
