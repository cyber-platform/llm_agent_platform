{
  "version": 1,
  "provider_id": "openai-chatgpt",
  "route_name": "openai-chatgpt",
  "display_name": "OpenAI ChatGPT",
  "auth": {
    "kind": "openai-oauth",
    "requirements": ["oauth_state"],
    "metadata": {
      "oauth_state_path": "openai-chatgpt/auth/oauth-account.json",
      "usage_state_path": "openai-chatgpt/usage/limits.json",
      "research_dependency_task": "tasks_descriptions/tasks/031-openai-codex-oauth-and-usage-research.md"
    }
  },
  "transport": {
    "kind": "openai-private-backend",
    "runtime_adapter": "openai_chatgpt",
    "metadata": {
      "backend_base_url_env": "OPENAI_CHATGPT_BACKEND_BASE_URL",
      "responses_path": "/responses",
      "usage_url_env": "OPENAI_CHATGPT_USAGE_URL",
      "user_agent_env": "OPENAI_CHATGPT_USER_AGENT",
      "originator_env": "OPENAI_CHATGPT_ORIGINATOR"
    }
  },
  "catalog": {
    "bootstrap": {
