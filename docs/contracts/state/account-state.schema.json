{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model-proxy/contracts/state/account-state.schema.json",
  "title": "Account state v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "last_used_at": {
      "type": "string",
      "format": "date-time"
    },
    "cooldown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "last_cooldown_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "quota_exhausted": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keys": {
          "type": "object",
          "description": "Mapping model key -> quota_exhausted_at. For per_provider scope the only key is '__provider__'.",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "quota_blocked_until": {
      "type": "string",
      "format": "date-time",
      "description": "Normalized provider-specific block boundary used for temporary quota blocking when provider semantics are not fully expressed by generic exhausted keys."
    },
    "quota_block_reason": {
      "type": "string",
      "minLength": 1,
      "description": "Normalized provider-specific reason for current quota block."
    },
    "quota_block_metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": true,
      "description": "Optional provider-specific metadata attached to normalized quota block state."
    }
  }
}
