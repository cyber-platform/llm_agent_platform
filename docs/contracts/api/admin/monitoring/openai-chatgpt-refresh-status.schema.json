{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model-proxy/contracts/api/admin/monitoring/openai-chatgpt-refresh-status.schema.json",
  "title": "OpenAI ChatGPT admin monitoring refresh status response v1",
  "description": "Status payload for a provider-wide monitoring refresh run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "refresh_id",
    "provider_id",
    "status",
    "processed_accounts",
    "total_accounts",
    "successful_accounts",
    "failed_accounts",
    "accounts"
  ],
  "$defs": {
    "account_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_name", "status"],
      "properties": {
        "account_name": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["pending", "refreshing", "success", "error", "skipped"]
        },
        "last_error": { "type": ["string", "null"] }
      }
    }
  },
  "properties": {
    "refresh_id": { "type": "string", "minLength": 1 },
    "provider_id": { "type": "string", "const": "openai-chatgpt" },
    "status": {
      "type": "string",
      "enum": ["queued", "running", "completed", "completed_with_errors", "error"]
    },
    "processed_accounts": { "type": "integer", "minimum": 0 },
    "total_accounts": { "type": "integer", "minimum": 0 },
    "successful_accounts": { "type": "integer", "minimum": 0 },
    "failed_accounts": { "type": "integer", "minimum": 0 },
    "accounts": {
      "type": "array",
      "items": { "$ref": "#/$defs/account_status" }
    }
  }
}
