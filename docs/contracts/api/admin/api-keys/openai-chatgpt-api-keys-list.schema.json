{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://model-proxy.local/contracts/api/admin/api-keys/openai-chatgpt-api-keys-list.schema.json",
  "title": "OpenAIChatGPTAdminApiKeysList",
  "description": "Admin API response for listing platform API keys for one openai-chatgpt group.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "provider_id",
    "group_id",
    "keys"
  ],
  "$defs": {
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_id",
        "label",
        "status",
        "masked_preview",
        "created_at"
      ],
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "revoked"
          ]
        },
        "masked_preview": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "properties": {
    "provider_id": {
      "type": "string",
      "const": "openai-chatgpt"
    },
    "group_id": {
      "type": "string",
      "minLength": 1
    },
    "keys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/key"
      }
    }
  }
}
