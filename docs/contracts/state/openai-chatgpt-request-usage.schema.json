{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model-proxy/contracts/state/openai-chatgpt-request-usage.schema.json",
  "title": "OpenAI ChatGPT request usage state v1",
  "description": "Account-scoped request-driven observability state that is separated from monitoring windows and does not define routing truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "provider_id",
    "request_counters"
  ],
  "$defs": {
    "token_totals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "request_counters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_requests": {
          "type": "integer",
          "minimum": 0
        },
        "successful_requests": {
          "type": "integer",
          "minimum": 0
        },
        "failed_requests": {
          "type": "integer",
          "minimum": 0
        },
        "last_request_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "last_request_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requested_model": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "tokens": {
          "$ref": "#/$defs/token_totals"
        },
        "metadata": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": true
        }
      }
    }
  },
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "provider_id": {
      "type": "string",
      "const": "openai-chatgpt"
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "request_counters": {
      "$ref": "#/$defs/request_counters"
    },
    "aggregate_tokens": {
      "$ref": "#/$defs/token_totals"
    },
    "last_request_summary": {
      "$ref": "#/$defs/last_request_summary"
    },
    "aggregates": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": true
    }
  }
}
