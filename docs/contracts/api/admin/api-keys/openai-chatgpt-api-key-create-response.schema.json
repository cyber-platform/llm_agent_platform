{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://model-proxy.local/contracts/api/admin/api-keys/openai-chatgpt-api-key-create-response.schema.json",
  "title": "OpenAIChatGPTAdminApiKeyCreateResponse",
  "description": "Admin API response returned once after creating a new platform API key for one openai-chatgpt group.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "key_id",
    "provider_id",
    "group_id",
    "label",
    "status",
    "masked_preview",
    "created_at",
    "raw_api_key"
  ],
  "properties": {
    "key_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "openai-chatgpt"
    },
    "group_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "active"
    },
    "masked_preview": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "raw_api_key": {
      "type": "string",
      "minLength": 1
    }
  }
}
