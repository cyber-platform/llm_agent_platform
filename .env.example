# === Google Cloud Configuration ===

# --- Vertex AI Mode (Credits) ---
# ID проекта, где включен Vertex AI API и привязан биллинг ($10 credits)
# Внимание: Это ID (my-project-123), а не Name (My Project)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# --- Quota Mode (OAuth / Gemini CLI Emulation) ---
# Опционально: Принудительно задать ID проекта для квот.
# Если не задано, прокси попытается обнаружить его автоматически.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- Quota parity controls ---
# Делает outbound quota transport максимально близким к gemini-cli (рекомендуется true)
STRICT_CLI_PARITY=true
# Дефолтная модель для OpenAI-compatible запросов без поля model
DEFAULT_QUOTA_MODEL=gemini-3-flash-preview-quota
# Переопределение Cloud Code endpoint (можно указывать capture-relay)
CLOUD_CODE_ENDPOINT=https://cloudcode-pa.googleapis.com/v1internal
# OAuth client для режима эмуляции gemini-cli.
# Обязателен для refresh Gemini quota токенов и запуска scripts/get_oauth_credentials.py.
GEMINI_CLI_CLIENT_ID=your-gemini-cli-client-id
GEMINI_CLI_CLIENT_SECRET=your-gemini-cli-client-secret

# --- Provider-specific OAuth credentials paths ---
USER_GEMINI_CREDS_PATH=secrets/user_gemini_credentials.json
USER_QWEN_CREDS_PATH=secrets/user_qwen_credentials.json

# --- Provider-specific accounts rotation configs ---
GEMINI_ACCOUNTS_CONFIG_PATH=secrets/gemini_accounts_config.json
QWEN_ACCOUNTS_CONFIG_PATH=secrets/qwen_accounts_config.json

# --- Qwen OAuth defaults ---
# QWEN_OAUTH_CLIENT_ID обязателен для device-flow и refresh токенов.
QWEN_OAUTH_CLIENT_ID=your-qwen-oauth-client-id
# Рекомендуемое значение scope для qwen OAuth device-flow:
# openid profile email model.completion
QWEN_OAUTH_SCOPE=openid profile email model.completion
QWEN_OAUTH_DEVICE_CODE_ENDPOINT=https://chat.qwen.ai/api/v1/oauth2/device/code
QWEN_OAUTH_TOKEN_ENDPOINT=https://chat.qwen.ai/api/v1/oauth2/token
QWEN_DEFAULT_RESOURCE_URL=https://dashscope.aliyuncs.com/compatible-mode

# --- HTTP pool tuning ---
HTTP_TIMEOUT_SECONDS=60
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
