{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/model-proxy/contracts/api/admin/monitoring/providers-list.schema.json",
  "title": "Admin monitoring providers list v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "providers"
  ],
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_id",
        "label",
        "has_monitoring",
        "capabilities"
      ],
      "properties": {
        "provider_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "account_count": {
          "type": "integer",
          "minimum": 0
        },
        "has_monitoring": {
          "type": "boolean"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "supports_provider_page"
          ],
          "properties": {
            "supports_provider_page": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "properties": {
    "providers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provider"
      }
    }
  }
}
