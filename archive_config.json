{
  "compression": {
    "method": "deflated",
    "level": 9
  },
  "gitignore": {
    "enabled": true,
    "paths": [
      ".gitignore"
    ]
  },
  "force_include": [
    ".kilo",
    "secrets",
    ".env",
    "services"
  ],
  "force_exclude": [
    ".venv"
  ],
  "output": {
    "filename": "llm_platform_backup.zip",
    "directory": "."
  }
}
