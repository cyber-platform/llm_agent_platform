{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://model-proxy.local/contracts/config/openai-chatgpt-api-key-registry.schema.json",
  "title": "OpenAIChatGPTApiKeyRegistry",
  "description": "Provider-scoped registry of locally managed platform API keys for openai-chatgpt groups.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "provider_id",
    "keys"
  ],
  "$defs": {
    "key": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key_id",
        "label",
        "group_id",
        "status",
        "key_hash",
        "masked_preview",
        "created_at"
      ],
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "group_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "revoked"
          ]
        },
        "key_hash": {
          "type": "string",
          "minLength": 1,
          "pattern": "^sha256:.+"
        },
        "masked_preview": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "revoked_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "provider_id": {
      "type": "string",
      "const": "openai-chatgpt"
    },
    "keys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/key"
      }
    }
  }
}
